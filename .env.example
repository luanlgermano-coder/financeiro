# ── Evolution API (WhatsApp) ──────────────────────────────────────────────────
# URL da sua instância Evolution API (ex: https://api.seudominio.com)
EVOLUTION_API_URL=https://sua-evolution-api.com

# Chave de autenticação da Evolution API (gerada no painel)
EVOLUTION_API_KEY=sua-api-key-aqui

# Nome da instância criada na Evolution API (ex: financeiro)
EVOLUTION_INSTANCE=financeiro

# ── Números de WhatsApp ───────────────────────────────────────────────────────
# Formato: código do país + DDD + número, sem espaços ou símbolos
LUAN_PHONE=5519982275251
BARBARA_PHONE=5519996026765

# ── IA (Gemini) ───────────────────────────────────────────────────────────────
# Chave da API Google Gemini para interpretação de mensagens via WhatsApp
# Obtida em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua-gemini-key-aqui

# ── Autenticação do dashboard ─────────────────────────────────────────────────
# Senha para acessar o dashboard (família)
DASHBOARD_PASSWORD=familia2026

# ── Banco de dados ────────────────────────────────────────────────────────────
# Caminho do arquivo SQLite (padrão: data/financeiro.db)
DB_PATH=./data/financeiro.db

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
